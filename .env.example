# Configurações AWS
AWS_REGION=us-east-1
AWS_PROFILE=default

# Nome do bucket S3 para dados Garmin
GARMIN_BUCKET_NAME=garmin-data-bucket

# Nome da tabela DynamoDB
GARMIN_TABLE_NAME=garmin-activities

# Configurações do Garmin (se necessário API key/token)
GARMIN_API_KEY=your_api_key_here
GARMIN_CLIENT_ID=your_client_id_here
GARMIN_CLIENT_SECRET=your_client_secret_here

# Configurações de ambiente
ENVIRONMENT=dev
LOG_LEVEL=INFO
